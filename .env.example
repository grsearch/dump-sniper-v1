# ============ Helius ============
# 普通 RPC (用于 sendTransaction、getAsset 等)
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# LaserStream gRPC (用于实时交易订阅)
HELIUS_LASERSTREAM_ENDPOINT=https://laserstream-mainnet-ewr.helius-rpc.com
HELIUS_LASERSTREAM_TOKEN=your_laserstream_token_here

# Staked sendTransaction endpoint (Business plan 提供)
HELIUS_STAKED_RPC_URL=https://staked.helius-rpc.com?api-key=YOUR_KEY

# ============ Birdeye ============
BIRDEYE_API_KEY=your_birdeye_key_here

# ============ Wallet ============
# 交易钱包私钥 (base58 编码)。仅 LIVE 模式需要。
WALLET_PRIVATE_KEY_BS58=

# ============ Server ============
DASHBOARD_PORT=3001
WEBHOOK_PORT=3001
# 监听网卡：0.0.0.0 = 全部，127.0.0.1 = 仅本地（用 SSH tunnel 时推荐）
BIND_HOST=0.0.0.0
# 可选：webhook 共享密钥，请求需带 X-Webhook-Secret header 或 Authorization: Bearer xxx
WEBHOOK_SECRET=
# 可选：dashboard 访问令牌，请求需带 X-Dashboard-Token header 或 ?token= 查询参数
DASHBOARD_TOKEN=

# ============ Mode ============
# DRY_RUN=true 时不实际下单，仅记录信号和模拟执行
DRY_RUN=true
